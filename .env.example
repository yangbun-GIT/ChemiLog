COMPOSE_PROJECT_NAME=chemilog
APP_ENV=dev
TZ=Asia/Seoul

# Public ports
CUSTOMER_WEB_PORT=80
ADMIN_WEB_PORT=8080
SPRING_MAIN_PORT=8081

# App profiles and origins
SPRING_PROFILE=dev
CUSTOMER_WEB_ORIGIN=http://localhost
ADMIN_WEB_ORIGIN=http://localhost:8080

# PostgreSQL
POSTGRES_DB=chemilog
POSTGRES_USER=chemilog_user
POSTGRES_PASSWORD=change_me_postgres_password

# JWT / auth
JWT_SECRET=change_me_to_very_long_random_secret
JWT_ACCESS_EXP_MINUTES=30
JWT_REFRESH_EXP_DAYS=14

# Internal service auth
INTERNAL_API_SECRET=change_me_internal_secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MAIN_MODEL=gpt-4o
OPENAI_POLICY_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MinIO
MINIO_ROOT_USER=chemilog
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET_IMAGES=chemilog-images
MINIO_BUCKET_RAG=chemilog-rag

# Rate limits
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_AI_PER_MINUTE=20
RATE_LIMIT_AI_PER_DAY=200
